{
  "name": "@smartagentkit/testing",
  "version": "0.1.10",
  "description": "Mock client for SmartAgentKit — run examples without funded wallets or deployed contracts",
  "license": "MIT",
  "author": "SmartAgentKit Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/smartagentkit/smartagentkit.git",
    "directory": "packages/testing"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@smartagentkit/sdk": "workspace:*",
    "viem": "^2.46.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "vitest": "^3.0.0",
    "typescript": "^5.7.0"
  }
}
