# SmartAgentKit Configuration
RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_API_KEY
BUNDLER_URL=https://api.pimlico.io/v2/base-sepolia/rpc?apikey=YOUR_PIMLICO_KEY

# Deployed module addresses (from `forge script Deploy.s.sol`)
SPENDING_LIMIT_HOOK=0xYOUR_SPENDING_LIMIT_HOOK_ADDRESS
ALLOWLIST_HOOK=0xYOUR_ALLOWLIST_HOOK_ADDRESS
EMERGENCY_PAUSE_HOOK=0xYOUR_EMERGENCY_PAUSE_HOOK_ADDRESS

# Owner wallet
OWNER_ADDRESS=0xYOUR_OWNER_ADDRESS_HERE
OWNER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# DEX Router addresses (must be allowlisted)
DEX_A_ROUTER=0xYOUR_DEX_A_ROUTER_ADDRESS
DEX_B_ROUTER=0xYOUR_DEX_B_ROUTER_ADDRESS

# Trading parameters
MIN_SPREAD_BPS=50
MAX_TRADE_SIZE_ETH=0.5
POLL_INTERVAL_MS=5000

# Mock mode: Run `pnpm start:mock` — no env vars needed
