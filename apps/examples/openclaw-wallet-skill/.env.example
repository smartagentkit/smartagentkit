# SmartAgentKit CLI Configuration
# These environment variables are used by the SmartAgentKit CLI
# when invoked by OpenClaw. Set them in your shell profile or
# pass them to the OpenClaw process.

SAK_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_API_KEY
SAK_BUNDLER_URL=https://api.pimlico.io/v2/base-sepolia/rpc?apikey=YOUR_PIMLICO_KEY
SAK_CHAIN=base-sepolia
SAK_OWNER_ADDRESS=0xYOUR_OWNER_ADDRESS_HERE
SAK_OWNER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
